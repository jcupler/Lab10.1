<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>

<h1><%= title %></h1>

<% if (Customers && Customers.length > 0) { %>
    <ul>
    <% for(var i = 0; i < Customers.length; i++) { %>
        <li> [<%= i %>] - Name: <%= Customers[i].name %> , Email: <%= Customers[i].email %></li>
    <% } %>
    </ul>
<% } else { %>
  <p>No customers found.</p>
<% } %>

</body>
</html>